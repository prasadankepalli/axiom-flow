{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AxiomFlow": "Debug"
    }
  },
  "AllowedHosts": "*",

  "AxiomFlow": {
    "OnFailure": "Flag",
    "GlobalPassThreshold": 0.7,
    "EnableLedger": true,
    "EnableTelemetry": true,
    "EvaluationTimeoutSeconds": 30,
    "BlockedResponseMessage": "This response has been blocked by Axiom-Flow semantic validation.",

    "CosmosLedger": {
      // Well-known static key for the local Cosmos DB Emulator
      "ConnectionString": "AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==",
      "DatabaseName": "axiom-flow",
      "ContainerName": "validation-artifacts",
      "PartitionKeyPath": "/sessionId",
      "DefaultTimeToLiveSeconds": 7776000,
      "ThroughputRUs": 400
    }
  }
}
